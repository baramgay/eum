# EUM 플랫폼 운영 환경 변수 템플릿
# Vercel/호스팅 환경의 Environment Variables에 등록하세요.
# 비밀 값은 절대 저장소에 커밋하지 마세요.

# --- 공개(Client) 환경 변수 ---
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
NEXT_PUBLIC_APP_URL=https://<production-domain>
NEXT_PUBLIC_KAKAO_MAP_KEY=<kakao-js-key>

# --- 서버 전용 환경 변수 ---
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# LLM 게이트웨이 (Qwen 전용)
PRIMARY_LLM_PROVIDER=qwen

# Qwen (OpenAI 호환 API)
QWEN_API_KEY=<qwen-api-key>
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-turbo



# Local / Self-hosted LLM (선택사항)
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=<local-model>

# cron / 외부 수집 인증 (운영 환경에서는 강력한 난수 사용)
CRON_SECRET=<random-secret-32-chars>
COLLECTION_SECRET=<random-secret-32-chars>

# 이메일 알림 (선택사항)
RESEND_API_KEY=<resend-key>
RESEND_FROM_EMAIL=noreply@eum.gyeongnam.go.kr
CENTER_NOTIFICATION_EMAIL=center@eum.gyeongnam.go.kr

# 테스트 시드 계정 (운영 환경에서는 사용하지 않도록 주의)
TEST_CENTER_EMAIL=center@eum.test
TEST_CENTER_PASSWORD=<secure-password>
TEST_AGENCY_EMAIL=changwon@eum.test
TEST_AGENCY_PASSWORD=<secure-password>

# 임베딩 API (선택사항, 미설정 시 OpenAI 기본값 사용)
EMBEDDING_API_KEY=<openai-api-key>
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small

# 오류/알림 수신 이메일 (선택사항)
ALERT_EMAIL_TO=center@eum.gyeongnam.go.kr

# 개발 단계 인증 우회 — 운영 환경에서는 반드시 false 또는 미설정
DEV_BYPASS=false

# 품질진단 서비스 키 (운영 환경에서는 서비스롤 키 대신 별도 설정 권장)
QUALITY_SECRET=<quality-secret-32-chars>
